    {
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "type": "stat",
      "title": "p95 — GET /{shortCode}",
      "description": "Жёлтый > 50ms, красный > 100ms",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 50   },
              { "color": "red",    "value": 150  }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"urlshortener\", uri=\"/api/v1/{shortCode}\"}[1m])) by (le)) * 1000",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },

    {
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "type": "stat",
      "title": "Процент ошибок 5xx",
      "description": "Жёлтый > 0.5%, красный > 1%",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 1    }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "(sum(rate(http_server_requests_seconds_count{application=\"urlshortener\", status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"urlshortener\"}[1m]))) * 100",
