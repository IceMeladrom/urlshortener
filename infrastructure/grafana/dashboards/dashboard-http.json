    {
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "type": "stat",
      "title": "RPS — GET /{shortCode}",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"urlshortener\", uri=\"/api/v1/{shortCode}\"}[1m]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },

    {
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "type": "stat",
      "title": "RPS — POST /shorten",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"urlshortener\", uri=\"/api/v1/shorten\"}[1m]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
