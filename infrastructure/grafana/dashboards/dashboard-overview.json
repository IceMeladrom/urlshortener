{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "HTTP",
      "url": "/d/urlshortener-http",
      "type": "link",
      "targetBlank": false
    },
    {
      "title": "Business",
      "url": "/d/urlshortener-business",
      "type": "link",
      "targetBlank": false
    },
    {
      "title": "Infrastructure",
      "url": "/d/urlshortener-infra",
      "type": "link",
      "targetBlank": false
    }
  ],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Общее состояние",
      "type": "row"
    },

    {
      "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "type": "stat",
      "title": "Время работы",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{application=\"urlshortener\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "type": "stat",
      "title": "Redis",
      "description": "1 = UP, 0 = DOWN",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 0.9  }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red"   },
                "1": { "text": "UP",   "color": "green" }
              }
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "redis_available{application=\"urlshortener\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background"
      }
    },

    {
      "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "type": "stat",
      "title": "CPU процесса",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "red",    "value": 0.8  }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"urlshortener\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },

    {
      "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "type": "stat",
      "title": "Heap используется",
      "description": "Жёлтый > 350MB, красный > 460MB (из 512MB лимита)",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null      },
              { "color": "yellow", "value": 350000000 },
              { "color": "red",    "value": 460000000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"urlshortener\", area=\"heap\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },

    {
      "id": 6,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "type": "stat",
      "title": "Активные потоки JVM",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60   },
              { "color": "red",    "value": 90   }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"urlshortener\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },

    {
      "id": 7,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "type": "stat",
      "title": "GC паузы (rate)",
      "description": "Количество GC-пауз в секунду. Жёлтый > 5/s, красный > 15/s",
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5    },
              { "color": "red",    "value": 15   }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{application=\"urlshortener\"}[1m])",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "JVM — динамика",
      "type": "row"
    },

    {
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "type": "timeseries",
      "title": "Heap — используется / выделено",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "committed" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"urlshortener\", area=\"heap\"})",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{application=\"urlshortener\", area=\"heap\"})",
          "legendFormat": "committed",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 12,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "type": "timeseries",
      "title": "CPU процесса",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"urlshortener\"}",
          "legendFormat": "cpu usage",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 13,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "type": "timeseries",
      "title": "JVM потоки",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "live" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "daemon" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "peak" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"urlshortener\"}",
          "legendFormat": "live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"urlshortener\"}",
          "legendFormat": "daemon",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"urlshortener\"}",
          "legendFormat": "peak",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },

    {
      "id": 14,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "type": "timeseries",
      "title": "GC паузы — длительность (p99)",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineInterpolation": "smooth", "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(jvm_gc_pause_seconds_bucket{application=\"urlshortener\"}[1m])) by (le))",
          "legendFormat": "p99 GC pause",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    }

  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["urlshortener", "load-testing"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "URL Shortener — Overview",
  "uid": "urlshortener-overview",
  "version": 1
}

