        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"urlshortener\", uri=\"/api/v1/shorten\"}[1m])) by (le)) * 1000",
          "legendFormat": "POST /shorten",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"urlshortener\", uri=\"/api/v1/{shortCode}\"}[1m])) by (le)) * 1000",
          "legendFormat": "GET /{shortCode}",
          "refId": "B"
        }
