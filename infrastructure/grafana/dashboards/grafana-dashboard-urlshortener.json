    {
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "type": "timeseries",
      "title": "RPS по эндпоинтам",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "POST /api/v1/shorten"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "GET /{shortCode}"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"urlshortener\", uri=\"/api/v1/shorten\"}[1m]))",
          "legendFormat": "POST /api/v1/shorten",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"urlshortener\", uri=\"/api/v1/{shortCode}\"}[1m]))",
          "legendFormat": "GET /{shortCode}",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "id": 4,
